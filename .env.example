# ─── Server ──────────────────────────────────────────
PORT=5000
JWT_SECRET=change_this_to_a_random_secret

# ─── AWS Configuration ──────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1

# ─── Development Mode ───────────────────────────────
# Set to true to skip real AWS calls (uses mock data)
DEV_MODE=false

# ─── AWS Lambda & EC2 ───────────────────────────────
AWS_LAMBDA_FUNCTION_NAME=Vaultify-AI-Tagger
EC2_DEFAULT_AMI=ami-xxxxxxxxxxxxxxxxx

# ─── Lambda ↔ Backend Auth ──────────────────────────
# Must match VAULTIFY_API_KEY in your Lambda env vars
VAULTIFY_API_KEY=change_this_to_a_random_key

# ─── Billing ────────────────────────────────────────
SITE_MARGIN=30
